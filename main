#include <iostream>
#include <random>
using namespace std;
class Data {
public:
    std::string value;
    Data(std::string value) {
        this-> value = value;
    }
};
template <typename T> class Node{
public:
    T *n;
    T *c;
    Node<T> *next;
    Node(T *n, T *c) {
        this-> n = n;
        this-> c = c;
        this-> next = nullptr;
    }
};
template <typename T> class LinkedList{
private:
    Node<T> *head;
    Node<T> *tail;
    Node<T> *playerPosition;
    int length;
     int goPast;
public:
    LinkedList(T *n, T *c){
        Node<T> *newNode = new Node<T>(n, c);
        head = newNode;
        tail = newNode;
        tail-> next = head;
        length = 1;
        goPast = 0;
        playerPosition = head;
    }
    ~LinkedList(){
        Node<T> *temp = head;
        while (head != nullptr){
            head = head-> next;
            delete temp;
            temp = head;
        }
    }
    void addSpace(T *n, T *c) {
        Node<T> newNode = new Node<T>(n, c);
        if(length == 0){
            head = newNode;
            tail = newNode;
            tail-> next = head;
        }
        else if(length < 40){
            tail-> next = newNode;
            tail = newNode;
            tail-> next = head;
            length++;

        }
        else{
            std::cout<<"failed"<<std::endl;
        }
    }
    void addMultiple(Node<T> nodes[]){
        for(int x = 0; x < nodes->length; x++){
            addSpace(nodes[x].name, nodes[x].color);
        }
    }
    void printSpace(){
        std::cout<<"Landed on: "<<playerPosition->getName()<<std::endl;
    }
void printGo(){
    std::cout<<"Times past GO: "<<goPast<<std::endl;
}
    void move(){
        int spaces = std::rand() % 11 + 1;
        for(int a = 0; a < spaces; a++){
            playerPosition = playerPosition-> next;
            if(playerPosition == head){
                goPast++;
                printGo();
            }
        }
        printSpace();
    }
};

int main() {
    Data *n = new Data("1st street");
    Data *c = new Data("brown");
    LinkedList<Data> *board = new LinkedList<Data>(n, c);
    board->addSpace(n, c);
    //Node spaces[] = {new Node(new Data("3rd street", "grey")), new Node(new Data("4th street", "grey"))};
    //board->addMultiple(spaces);
   // board->move();
    return 1;
}
