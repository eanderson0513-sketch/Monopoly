#include <iostream>
#include <random>
using namespace std;
#include <string>
class Node{
public:
    string name;
    string color;
    Node *next;
    Node(string name, string color) {
        this-> name = name;
        this-> color = color;
        this-> next = nullptr;
    }
    Node() {

    }
};
class LinkedList{
private:
    Node *head;
    Node *tail;
    Node *playerPosition;
    int length;
    int goPast;
public:
    LinkedList(){
        head = nullptr;
        tail = nullptr;
        length = 0;
        goPast = 0;
    }
    ~LinkedList(){
        Node *temp = head;
        while (head != nullptr){
            head = head-> next;
            delete temp;
            temp = head;
        }
    }
    void addSpace(string name, string color) {
        Node* newNode = new Node(name, color);
        if(length == 0){
            head = newNode;
            tail = newNode;
            tail-> next = head;
            length++;
            playerPosition = head;
        }
        else if(length < 40){
            tail-> next = newNode;
            tail = newNode;
            tail-> next = head;
            length++;
        }

        else{
            cout<<"failed"<<endl;
        }
    }
    void addMultiple(Node nodes[], int size){
        for(int x = 0; x < size; x++){
            Node newNode = nodes[x];
            addSpace(newNode.name, newNode.color);
        }
    }
    void printSpace(){
        cout<<"Landed on: "<<playerPosition->name<<" of color "<< playerPosition->color<<endl;
    }
void printGo(){
    cout<<"Times past GO: "<<goPast<<endl;
}
    void move(){
        srand(time(nullptr));
        int spaces = rand() % 11 + 1;
        for(int a = 0; a < spaces; a++){
            playerPosition = playerPosition-> next;
            if(playerPosition == head){
                goPast++;
                printGo();
            }
        }
        printSpace();
    }
};

int main() {
    //Node *s1 = new Node("First street", "brown");
    LinkedList board;
    board.addSpace("First street", "brown");
   Node spaces[] = {{"Second street", "brown"}, {"Third street", "grey"}};
    board.addMultiple(spaces, sizeof(spaces)/sizeof(Node));
    Node stress[50];
    for (int x = 0; x < 50; x++) {
        stress[x] = Node(to_string(x), "a");
    }
    board.addMultiple(stress, 50);
    board.move();
    return 1;
}
