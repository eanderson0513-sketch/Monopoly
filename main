#include <iostream>
#include <random>
using namespace std;
class Node{
public:
    string name;
    string color;
    Node *next;
    Node(string name, string color) {
        this-> name = name;
        this-> color = color;
        this-> next = nullptr;
    }
};
class LinkedList{
private:
    Node *head;
    Node *tail;
    Node *playerPosition;
    int length;
    int goPast;
public:
    LinkedList(){
        head = nullptr;
        tail = nullptr;
        length = 0;
        goPast = 0;
        playerPosition = head;
    }
    ~LinkedList(){
        Node *temp = head;
        while (head != nullptr){
            head = head-> next;
            delete temp;
            temp = head;
        }
    }
    void addSpace(string name, string color) {
        Node* newNode = new Node(name, color);
        if(length == 0){
            head = newNode;
            tail = newNode;
            tail-> next = head;
            length++;
        }
        else if(length < 40){
            tail-> next = newNode;
            tail = newNode;
            tail-> next = head;
            length++;
        }

        else{
            std::cout<<"failed"<<std::endl;
        }
    }
    void addMultiple(Node nodes[], int size){
        for(int x = 0; x < size; x++){
            Node newNode = nodes[x];
            addSpace(newNode.name, newNode.color);
        }
    }
    void printSpace(){
        std::cout<<"Landed on: "<<playerPosition<<std::endl;
    }
void printGo(){
    std::cout<<"Times past GO: "<<goPast<<std::endl;
}
    void move(){
        int spaces = std::rand() % 11 + 1;
        for(int a = 0; a < spaces; a++){
            playerPosition = playerPosition-> next;
            if(playerPosition == head){
                goPast++;
                printGo();
            }
        }
        printSpace();
    }
};

int main() {
    //Node *s1 = new Node("First street", "brown");
    LinkedList board = new LinkedList();
    board.addSpace("First street", "brown");
   Node spaces[] = {{"Second street", "brown"}, {"Third street", "grey"}};
    board.addMultiple(spaces, 2);
    board.move();
    return 1;
}
